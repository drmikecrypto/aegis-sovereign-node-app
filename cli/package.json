{
  "name": "aegis-node-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Aegis sovereign Sonic node manager and local RPC/circuit static server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aegis-node": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:proxy": "node dist/server.js",
    "dev:proxy": "tsx src/server.ts",
    "dev": "tsx src/index.ts",
    "lint": "eslint --ext .ts src"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "ora": "^8.0.1",
    "semver": "^7.6.3",
    "serve-static": "^1.15.0",
    "tar": "^6.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "@types/semver": "^7.5.8",
    "@types/tar": "^6.1.11",
    "tsx": "^4.15.7",
    "typescript": "^5.6.3"
  }
}
